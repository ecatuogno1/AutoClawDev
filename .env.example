# AutoClawDev environment template
#
# AutoClawDev shell scripts read environment variables directly; this file is a
# template only. Copy values into your shell, .envrc, or another loader.
# Blank values mean "set per project or run" or "let project config decide."

# Core paths
# AUTOCLAWDEV_HOME=~/.autoclawdev
# AUTOCLAWDEV_WORKSPACE=~/.openclaw/workspace/autoresearch
# AUTOCLAWDEV_PROJECTS_DIR=~/.local/lib/autoclawdev/projects
# AUTOCLAWDEV_RUNNER=/absolute/path/to/AutoClawDev/scripts/runner.sh
# AUTOCLAWDEV_UI_LAUNCHER=/absolute/path/to/AutoClawDev/bin/autoclawdev-ui
# AUTOCLAWDEV_REPO_ROOT=/absolute/path/to/AutoClawDev
# AUTOCLAW_DEV_DIR=~/Developer

# Project and runner inputs
# AUTOCLAWDEV_PROJECT=
# AUTOCLAWDEV_REPO=
# AUTOCLAWDEV_PROJECT_CONFIG_FILE=
# AUTOCLAWDEV_NAME=
# AUTOCLAWDEV_PROGRAM=
# AUTOCLAWDEV_EXPERIMENTS=
# AUTOCLAWDEV_TEST_CMD=
# AUTOCLAWDEV_LINT_CMD=
# AUTOCLAWDEV_SECURITY_CMD=
# AUTOCLAWDEV_SECURITY_DEPENDENCY_CMD=
# AUTOCLAWDEV_PERFORMANCE_CMD=
# AUTOCLAWDEV_PROFILE_VALIDATION_JSON=
# AUTOCLAWDEV_DEV_URL=
# AUTOCLAWDEV_BASE_BRANCH=
# AUTOCLAWDEV_INTEGRATION_BRANCH=
# AUTOCLAWDEV_LANDING_REPO=

# Workflow and orchestration
# AUTOCLAWDEV_TEAM_PROFILE=reliability
# AUTOCLAWDEV_WORKFLOW_TYPE=standard
# AUTOCLAWDEV_SPEED_PROFILE=balanced
# AUTOCLAWDEV_MAX_PARALLEL_CYCLES=1
# AUTOCLAWDEV_BATCH_RESEARCH_COUNT=3
# AUTOCLAWDEV_BATCH_RESEARCH_AUTO=0
# AUTOCLAWDEV_RUNNER_MODE=parent
# AUTOCLAWDEV_SKIP_PROJECT_LOCK=0
# AUTOCLAWDEV_CYCLE_COOLDOWN_SECONDS=0
# AUTOCLAWDEV_GOAL=
# AUTOCLAWDEV_TARGET_FILE=
# AUTOCLAWDEV_DOMAIN=backend
# AUTOCLAWDEV_DIRECTIVE=feature
# AUTOCLAW_BUILD_MAX_ATTEMPTS=3
# AUTOCLAWDEV_WIGMAN_SUCCESS_SLEEP_SECONDS=3
# AUTOCLAWDEV_WIGMAN_FAILURE_SLEEP_SECONDS=20
# AUTOCLAWDEV_WIGMAN_MAX_CONSECUTIVE_FAILURES=3

# Models
# AUTOCLAWDEV_RESEARCH_MODEL=opus
# AUTOCLAWDEV_PLANNING_MODEL=opus
# AUTOCLAWDEV_IMPL_MODEL=
# AUTOCLAWDEV_REVIEW_MODEL=opus
# AUTOCLAWDEV_FIX_MODEL=
# AUTOCLAWDEV_CODEX_MODEL=gpt-5.4
# AUTOCLAWDEV_CODEX_FIX_MODEL=gpt-5.3-codex-spark
# CLAUDE_MODEL=opus

# Validation and review
# AUTOCLAWDEV_AGENT_TIMEOUT_DEFAULT=900
# AUTOCLAWDEV_AGENT_TIMEOUT_CODEX=1800
# AUTOCLAWDEV_AGENT_TIMEOUT_OPUS=1200
# AUTOCLAWDEV_AGENT_TIMEOUT_CODERABBIT=600
# AUTOCLAWDEV_AGENT_TIMEOUT_FIX=600
# AUTOCLAWDEV_VALIDATION_TIMEOUT=1200
# AUTOCLAWDEV_DEPENDENCY_BOOTSTRAP_TIMEOUT=1800
# AUTOCLAWDEV_VALIDATION_MODE=serial
# AUTOCLAWDEV_ALLOW_PREEXISTING_TEST_FAILURES=0
# AUTOCLAWDEV_CODERABBIT_MAX_ROUNDS=3
# AUTOCLAWDEV_VALIDATION_FIX_ATTEMPTS=2
# AUTOCLAWDEV_CAPTURE_VALIDATION_BASELINE=1
# AUTOCLAWDEV_SKIP_PENNY_ON_CLEAN_CODERABBIT=
# AUTOCLAWDEV_REVIEW_DEPTH=

# Memory, prompts, and GitHub context
# AUTOCLAWDEV_MEMORY_ENABLED=1
# AUTOCLAWDEV_MEMORY_DIR=~/.openclaw/workspace/autoresearch/memory
# AUTOCLAWDEV_MEMORY_SCRIPT=/absolute/path/to/AutoClawDev/scripts/memory_cache.py
# AUTOCLAWDEV_VALIDATION_BASELINES_DIR=~/.openclaw/workspace/autoresearch/validation-baselines
# AUTOCLAWDEV_PROMPTS_DIR=/absolute/path/to/AutoClawDev/scripts/prompts
# AUTOCLAWDEV_BROWSER_SNAPSHOT=/absolute/path/to/AutoClawDev/scripts/browser_snapshot.mjs
# AUTOCLAWDEV_GH_CONTEXT_REFRESH_SECONDS=30
# AUTOCLAWDEV_GH_ISSUES_CACHE_DIR=~/.openclaw/workspace/autoresearch/gh-cache
# AUTOCLAWDEV_GH_ISSUES_CACHE_TTL_SECONDS=300
# AUTOCLAWDEV_RECENT_CONTEXT=
# AUTOCLAWDEV_GH_ISSUES_CONTEXT=
# AUTOCLAWDEV_BASELINE_JSON=

# Auto-managed runner state
# AUTOCLAWDEV_ASSIGNED_EXP_ID=
# AUTOCLAWDEV_ASSIGNED_CYCLE_NUMBER=
# AUTOCLAWDEV_CHANGED_FILES=

# Dashboard and server
# PORT=4100
# AUTOCLAWDEV_UI_PID_FILE=~/.openclaw/workspace/autoresearch/autoclawdev-ui.pid
# AUTOCLAWDEV_UI_LOG_FILE=~/.openclaw/workspace/autoresearch/autoclawdev-ui.log
# AUTOCLAWDEV_UI_SERVICE_LABEL=com.autoresearch.dashboard
# AUTOCLAWDEV_UI_LAUNCH_AGENTS_DIR=~/Library/LaunchAgents
# AUTOCLAWDEV_UI_PLIST_FILE=~/Library/LaunchAgents/com.autoresearch.dashboard.plist

# Standard shell overrides used by AutoClawDev
# EDITOR=nano
# TMPDIR=/tmp
