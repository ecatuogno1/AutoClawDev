{
  "name": "autoclawdev",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @autoclawdev/server dev & pnpm --filter @autoclawdev/web dev",
    "dev:web": "pnpm --filter @autoclawdev/web dev",
    "dev:server": "pnpm --filter @autoclawdev/server dev",
    "build": "pnpm --filter @autoclawdev/types build && pnpm --filter @autoclawdev/web build && pnpm --filter @autoclawdev/server build",
    "start": "pnpm --filter @autoclawdev/server start"
  }
}
