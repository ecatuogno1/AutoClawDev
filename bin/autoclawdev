}

# ── Parse -p <profile> flag from any position ────────────────────────
_parse_profile_flag() {
  local args=("$@")
  PARSED_PROFILE=""
  PARSED_ARGS=()
  local i=0
  while [ $i -lt ${#args[@]} ]; do
    if [ "${args[$i]}" = "-p" ] && [ $((i + 1)) -lt ${#args[@]} ]; then
      PARSED_PROFILE="${args[$((i + 1))]}"
      i=$((i + 2))
    else
      PARSED_ARGS+=("${args[$i]}")
      i=$((i + 1))
    fi
  done
}

# ── Route ────────────────────────────────────────────────────────────
case "${1:-}" in
  # ── Core commands ──────────────────────────────────────────────────
  run)
    shift
    _parse_profile_flag "$@"
    if [ -n "$PARSED_PROFILE" ]; then
      # Single profile mode: autoclaw run project N -p security
      cmd_profile_run "$PARSED_PROFILE" "${PARSED_ARGS[0]:-}" "${PARSED_ARGS[1]:-1}"
    else
      # Full cycle mode: autoclaw run project [passes]
      cmd_full_cycle "${PARSED_ARGS[0]:-}" "${PARSED_ARGS[1]:-1}"
    fi
    ;;
  review|deep-review)
    "$REPO_ROOT/scripts/deep-review.sh" "${@:2}" ;;
  build)
    "$REPO_ROOT/scripts/build.sh" "${@:2}" ;;
  loop|wigman|ralph)
    shift
    _parse_profile_flag "$@"
    if [ -n "$PARSED_PROFILE" ]; then
      # Single profile loop: autoclaw loop project N -p security
      cmd_profile_wigman "$PARSED_PROFILE" "${PARSED_ARGS[0]:-}" "${PARSED_ARGS[1]:-25}" "${PARSED_ARGS[2]:-${AUTOCLAWDEV_MAX_PARALLEL_CYCLES:-3}}"
    else
      # Full cycle loop: continuous runs until stopped
      cmd_loop "${PARSED_ARGS[0]:-}"
    fi
    ;;
  stop)      cmd_stop "${2:-}" ;;

  # ── Projects ───────────────────────────────────────────────────────
  list|ls)   cmd_list ;;
  add)       cmd_add "${2:-}" ;;
  log)       cmd_log "${2:-}" ;;
  status|st) cmd_status ;;
  github|gh) cmd_github "${2:-}"; echo "" ;;

  # ── Tools ──────────────────────────────────────────────────────────
  audit)     cmd_audit "${2:-}" "${3:-}" ;;
  ingest|ingest-memory) "$REPO_ROOT/scripts/ingest-to-memory.sh" "${@:2}" ;;
  migrate) "$REPO_ROOT/scripts/migrate-to-autoclaw.sh" "${@:2}" ;;
  memory|memory-init|mem-init) cmd_memory_init "${2:-}" ;;
  ui)        "$UI_LAUNCHER" "${@:2}" ;;
  doctor)    cmd_doctor ;;

  # ── Advanced ───────────────────────────────────────────────────────
  workflow)  cmd_workflow_run "${2:-standard}" "${3:-}" "${4:-5}" ;;
  cycle)     cmd_cycle "${2:-}" "${3:-}" ;;
  tail)      cmd_tail "${2:-}" ;;
  dashboard) cmd_dashboard ;;
  profiles)  cmd_profiles ;;
  workflows) cmd_workflows ;;

  # ── Legacy aliases (still work, route to new commands) ─────────────
  security)     cmd_profile_run "security" "${2:-}" "${3:-5}" ;;
  performance)  cmd_profile_run "performance" "${2:-}" "${3:-5}" ;;
  quality)      cmd_profile_run "quality" "${2:-}" "${3:-5}" ;;
  issues)       cmd_profile_run "issues" "${2:-}" "${3:-5}" ;;
  implement)    cmd_workflow_run "implement-only" "${2:-}" "${3:-5}" ;;
  review-run)   cmd_workflow_run "review-only" "${2:-}" "${3:-5}" ;;
  fast-ship)    cmd_workflow_run "fast-ship" "${2:-}" "${3:-5}" ;;
  research)     cmd_workflow_run "research-only" "${2:-}" "${3:-5}" ;;
  profile)      cmd_profile_run "${2:-}" "${3:-}" "${4:-5}" ;;
  security-wigman|security-ralph) cmd_profile_wigman "security" "${2:-}" "${3:-25}" "${4:-${AUTOCLAWDEV_MAX_PARALLEL_CYCLES:-3}}" ;;
  profile-wigman|profile-ralph) cmd_profile_wigman "${2:-}" "${3:-}" "${4:-25}" "${5:-${AUTOCLAWDEV_MAX_PARALLEL_CYCLES:-3}}" ;;
  # Old profile names still route through (runner normalizes them)
  test-hardening|frontend-quality|dependency-hygiene|api-contract|data-integrity|privacy-compliance|mobile-quality|refactor-safety|issue-burner)
    cmd_profile_run "$1" "${2:-}" "${3:-5}" ;;
  *-wigman)
    local _profile="${1%-wigman}"
    cmd_profile_wigman "$_profile" "${2:-}" "${3:-25}" "${4:-${AUTOCLAWDEV_MAX_PARALLEL_CYCLES:-3}}" ;;

  # ── Meta ───────────────────────────────────────────────────────────
  version|--version|-V) printf "%s\n" "$VERSION" ;;
  help|--help|-h) cmd_help ;;
  "")        cmd_interactive ;;
  *)         gum style --foreground 203 "Unknown command: $1"; echo ""; cmd_help ;;
esac
