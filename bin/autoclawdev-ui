#!/bin/bash
set -euo pipefail

resolve_source() {
  local source_path=$1
  while [ -L "$source_path" ]; do
    local source_dir
    source_dir=$(cd -P "$(dirname "$source_path")" && pwd)
    source_path=$(readlink "$source_path")
    [[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
  done
  cd -P "$(dirname "$source_path")" && pwd
}

SCRIPT_DIR="$(resolve_source "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PORT="${PORT:-4100}"
SERVER_ENTRY="$REPO_ROOT/apps/server/dist/index.js"
PID_FILE="${AUTOCLAWDEV_UI_PID_FILE:-$HOME/.openclaw/workspace/autoresearch/autoclawdev-ui.pid}"
LOG_FILE="${AUTOCLAWDEV_UI_LOG_FILE:-$HOME/.openclaw/workspace/autoresearch/autoclawdev-ui.log}"
SERVICE_LABEL="${AUTOCLAWDEV_UI_SERVICE_LABEL:-com.autoresearch.dashboard}"
LAUNCH_AGENTS_DIR="${AUTOCLAWDEV_UI_LAUNCH_AGENTS_DIR:-$HOME/Library/LaunchAgents}"
PLIST_FILE="${AUTOCLAWDEV_UI_PLIST_FILE:-$LAUNCH_AGENTS_DIR/${SERVICE_LABEL}.plist}"
OPEN_BROWSER=1
BACKGROUND=0
COMMAND="start"

resolve_home_dir() {
  local current_home
  current_home=$(eval echo ~ 2>/dev/null || true)
  if [ -n "$current_home" ]; then
    printf '%s' "$current_home"
    return 0
  fi
  printf '%s' "$HOME"
}

resolve_repo_root() {
  local autoclaw_path
  autoclaw_path=$(command -v autoclawdev 2>/dev/null || true)
  if [ -n "$autoclaw_path" ]; then
    cd "$(resolve_source "$autoclaw_path")/.." && pwd
    return 0
  fi
  cd "$SCRIPT_DIR/.." && pwd
}

resolve_shell_path() {
  local current_path shell_path

  shell_path="${SHELL:-}"
  if [ -n "$shell_path" ] && [ -x "$shell_path" ]; then
    current_path=$("$shell_path" -lc 'printf %s "$PATH"' 2>/dev/null || true)
    if [ -n "$current_path" ]; then
      printf '%s' "$current_path"
      return 0
    fi
  fi

  current_path=$(bash -lc 'printf %s "$PATH"' 2>/dev/null || true)
  if [ -n "$current_path" ]; then
    printf '%s' "$current_path"
    return 0
  fi

  printf '%s' "/usr/local/bin:/usr/bin:/bin"
}

usage() {
  cat <<'EOF'
Usage: autoclawdev-ui [--background] [--no-open] [--check] [--stop]

  --background  Start the dashboard server and return immediately.
  --no-open     Do not open the browser.
  --check       Exit 0 only if the dashboard responds on localhost.
  --stop        Stop the dashboard started by this launcher.
EOF
}

is_responding() {
  curl -fsS "http://localhost:${PORT}/api/active" >/dev/null 2>&1
}

service_target() {
  printf "gui/%s/%s" "$(id -u)" "$SERVICE_LABEL"
}

wait_for_ready() {
  local attempt
  for attempt in $(seq 1 50); do
    if is_responding; then
      return 0
    fi
    sleep 0.2
  done
  return 1
}

write_launch_agent() {
  local current_home current_path launch_repo_root workspace_root

  current_home=$(resolve_home_dir)
  current_path=$(resolve_shell_path)
  launch_repo_root=$(resolve_repo_root)
  workspace_root="${AUTOCLAWDEV_WORKSPACE:-$current_home/.openclaw/workspace/autoresearch}"

  mkdir -p "$LAUNCH_AGENTS_DIR"
  cat > "$PLIST_FILE" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>${SERVICE_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
      <string>$(command -v node)</string>
      <string>${SERVER_ENTRY}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${launch_repo_root}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${LOG_FILE}</string>
    <key>StandardErrorPath</key>
    <string>${LOG_FILE}</string>
    <key>EnvironmentVariables</key>
    <dict>
      <key>AUTOCLAWDEV_REPO_ROOT</key>
      <string>${launch_repo_root}</string>
      <key>AUTOCLAWDEV_RUNNER</key>
      <string>${launch_repo_root}/scripts/runner.sh</string>
      <key>AUTOCLAWDEV_WORKSPACE</key>
      <string>${workspace_root}</string>
      <key>HOME</key>
      <string>${current_home}</string>
      <key>PATH</key>
      <string>${current_path}</string>
      <key>PORT</key>
      <string>${PORT}</string>
    </dict>
  </dict>
</plist>
EOF
}

bootout_service() {
  launchctl bootout "$(service_target)" >/dev/null 2>&1 \
    || launchctl bootout "gui/$(id -u)" "$PLIST_FILE" >/dev/null 2>&1 \
    || true
}

start_service() {
  write_launch_agent
  bootout_service
  launchctl bootstrap "gui/$(id -u)" "$PLIST_FILE" >/dev/null 2>&1
  launchctl kickstart -k "$(service_target)" >/dev/null 2>&1 || true
}

stop_server() {
  bootout_service
  if [ -f "$PID_FILE" ]; then
    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill "$pid" >/dev/null 2>&1 || true
      wait "$pid" 2>/dev/null || true
      echo "Stopped AutoClawDev dashboard (pid $pid)"
    fi
    rm -f "$PID_FILE"
  fi
  if is_responding; then
    echo "Dashboard is still responding after stop request."
    return 1
  fi
  echo "Stopped AutoClawDev dashboard."
  return 0
}

while [ $# -gt 0 ]; do
  case "$1" in
    --background)
      BACKGROUND=1
      ;;
    --no-open)
      OPEN_BROWSER=0
      ;;
    --check)
      COMMAND="check"
      ;;
    --stop)
      COMMAND="stop"
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

case "$COMMAND" in
  check)
    if is_responding; then
      echo "AutoClawDev dashboard is responding at http://localhost:${PORT}"
      exit 0
    fi
    echo "AutoClawDev dashboard is not responding at http://localhost:${PORT}" >&2
    exit 1
    ;;
  stop)
    stop_server
    exit 0
    ;;
esac

mkdir -p "$(dirname "$PID_FILE")"
mkdir -p "$(dirname "$LOG_FILE")"

if [ ! -f "$SERVER_ENTRY" ]; then
  echo "Missing build output: $SERVER_ENTRY" >&2
  echo "Run 'make build' first." >&2
  exit 1
fi

if is_responding; then
  echo "Dashboard already running at http://localhost:${PORT}"
  if [ "$OPEN_BROWSER" -eq 1 ]; then
    open "http://localhost:${PORT}"
  fi
  exit 0
fi

echo "🦞 Starting AutoClawDev dashboard on http://localhost:${PORT}"
if [ "$BACKGROUND" -eq 1 ]; then
  start_service
  if ! wait_for_ready; then
    echo "Dashboard failed to start." >&2
    exit 1
  fi
  if [ "$OPEN_BROWSER" -eq 1 ]; then
    open "http://localhost:${PORT}"
  fi
  echo "Dashboard running via launchd service ${SERVICE_LABEL}."
  exit 0
fi

AUTOCLAWDEV_REPO_ROOT="$REPO_ROOT" \
AUTOCLAWDEV_RUNNER="$REPO_ROOT/scripts/runner.sh" \
AUTOCLAWDEV_WORKSPACE="${AUTOCLAWDEV_WORKSPACE:-$HOME/.openclaw/workspace/autoresearch}" \
PORT="$PORT" \
node "$SERVER_ENTRY" &
SERVER_PID=$!
echo "$SERVER_PID" > "$PID_FILE"

if ! wait_for_ready; then
  echo "Dashboard failed to start." >&2
  kill "$SERVER_PID" >/dev/null 2>&1 || true
  rm -f "$PID_FILE"
  exit 1
fi

if [ "$OPEN_BROWSER" -eq 1 ]; then
  open "http://localhost:${PORT}"
fi

cleanup() {
  if kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    kill "$SERVER_PID" >/dev/null 2>&1 || true
  fi
  rm -f "$PID_FILE"
}

trap cleanup EXIT INT TERM

echo "Dashboard running. Press Ctrl+C to stop."
wait "$SERVER_PID"
